        stage('Create Kind Cluster') {
            steps {
                sh '''
                kind create cluster --name ci-cluster || true
                '''
            }
        }

        stage('Generate Manifests') {
            steps {
                sh '''
                mkdir -p k8s

                kubectl create deployment nginx \
                  --image=$IMAGE \
                  --dry-run=client -o yaml > k8s/deployment.yaml

                kubectl expose deployment nginx \
                  --port=80 \
                  --type=NodePort \
                  --dry-run=client -o yaml > k8s/service.yaml
                '''
            }
        }

        stage('Deploy to Kind') {
            steps {
                sh '''
                docker run --rm \
                  --network kind \
                  -v ~/.kube:/root/.kube \
                  bitnami/kubectl:latest \
                  kubectl apply -f k8s/
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                docker run --rm \
                  --network kind \
                  -v ~/.kube:/root/.kube \
                  bitnami/kubectl:latest \
                  kubectl rollout status deployment/nginx
                '''
            }
        }

        stage('Cleanup') {
            steps {
                sh '''
                kind delete cluster --name ci-cluster || true
                '''
            }
        }
    }
}
